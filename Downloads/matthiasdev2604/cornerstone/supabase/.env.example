# =============================================================
#  EXALT DIGITAL — BACKEND SECRETS
#  Set each of these in: Supabase dashboard →
#  Project Settings → Edge Functions → Secrets
#
#  DO NOT commit real values to git. This file is a template.
# =============================================================

# ── Stripe ────────────────────────────────────────────────────
# Find at: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# Get this when you add a webhook endpoint in Stripe:
# dashboard.stripe.com/webhooks → Add endpoint
# URL: https://YOUR_PROJECT.supabase.co/functions/v1/stripe-webhook
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Google Ads ────────────────────────────────────────────────
# 1. Create a Google Ads Manager Account (MCC) at:
#    ads.google.com/intl/en_au/home/tools/manager-accounts
#
# 2. Apply for a Developer Token inside the MCC:
#    Tools → API Centre → Apply for Basic Access
#    (takes 1–5 business days to approve)
#
# 3. Create OAuth2 credentials in Google Cloud Console:
#    console.cloud.google.com → APIs & Services → Credentials
#    → Create credentials → OAuth client ID → Desktop app
#
# 4. Run the OAuth flow once to get a refresh token:
#    Use the Google OAuth Playground or a local script.
#    See: developers.google.com/google-ads/api/docs/get-started/oauth-cloud-project

# From step 2 (your MCC → Tools → API Centre)
GOOGLE_ADS_DEVELOPER_TOKEN=REPLACE_ME

# From step 3 (Google Cloud Console OAuth credentials)
GOOGLE_ADS_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=REPLACE_ME

# From step 4 (one-time OAuth flow)
GOOGLE_ADS_REFRESH_TOKEN=REPLACE_ME

# Your Google Ads account ID (the one campaigns are created in)
# Find it in the top-right of Google Ads dashboard — format: 123-456-7890
# Enter WITHOUT dashes: 1234567890
GOOGLE_ADS_CUSTOMER_ID=REPLACE_ME

# Your MCC account ID (same format, no dashes)
# If you only have one account (no MCC), use the same ID as above
GOOGLE_ADS_MANAGER_ACCOUNT_ID=REPLACE_ME

# ── Anthropic (for generating ad copy) ───────────────────────
# Find at: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Email — Resend ────────────────────────────────────────────
# Sign up free at: resend.com
# Create an API key at: resend.com/api-keys
RESEND_API_KEY=re_REPLACE_ME

# The email address campaigns and confirmations are sent FROM
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=campaigns@yourdomain.com

# Your email — where you receive notifications about new orders
ADMIN_EMAIL=you@yourdomain.com
